/target
**/*.rs.bk
Cargo.lock
# Bundled model weights are committed deliberately (see models/); but never
# commit captured frames, templates, or any biometric data:
*.onnx.tmp
/var
*.embedding
*.template

# Model weights are fetched into models/ (see models/README.md), not committed
# to git — glintr100.onnx is 261MB and GitHub blocks >100MB without LFS.
models/*.onnx

# but DO keep our own tiny trained adapter
!models/ir_adapter.onnx
