#!/usr/bin/make -f
# Launchpad builders have no network: the orig tarball carries vendor/ (all
# crates, wired up by .cargo/config.toml) and ort-prebuilt/ (onnxruntime
# release libs), both staged by scripts/build-ppa-source.sh.
include /usr/share/dpkg/architecture.mk

export CARGO_HOME = $(CURDIR)/debian/cargo_home

%:
	dh $@

override_dh_auto_build:
	# --frozen: build against the committed Cargo.lock exactly (reproducible);
	# --offline: use only the vendored crates (Launchpad builders have no net).
	# NB: the PPA targets only the current Ubuntu LTS, whose cargo reads the
	# format-v4 lock fine. (Older LTSs like noble ship cargo 1.75, which can't
	# parse v4 AND can't compile our ort/edition-2024 deps anyway; those users
	# get the universal .deb from the GitHub release, not the PPA.)
	cargo build --release --frozen --offline

override_dh_auto_test:
	# Tests need camera/TPM hardware; not runnable on builders.

override_dh_auto_clean:
	rm -rf target debian/cargo_home

# dh_clean's default cruft sweep deletes *.orig / *~ recursively, which
# nukes vendored files (vendor/*/Cargo.toml.orig) that cargo's checksum
# manifests require; cargo --frozen then fails on the builder.
override_dh_clean:
	dh_clean -Xvendor/

override_dh_auto_install:
	install -D -m0755 target/release/irlumed debian/irlume/usr/bin/irlumed
	install -D -m0755 target/release/irlume debian/irlume/usr/bin/irlume
	install -D -m0644 target/release/libpam_irlume.so \
		debian/irlume/usr/lib/$(DEB_HOST_MULTIARCH)/security/pam_irlume.so
	install -D -m0644 models/glintr100.onnx \
		debian/irlume/usr/share/irlume/models/glintr100.onnx
	install -D -m0644 models/face_detection_yunet_2023mar.onnx \
		debian/irlume/usr/share/irlume/models/face_detection_yunet_2023mar.onnx
	install -D -m0644 models/face_landmark.onnx \
		debian/irlume/usr/share/irlume/models/face_landmark.onnx
	install -D -m0644 models/blaze_face_short_range.onnx \
		debian/irlume/usr/share/irlume/models/blaze_face_short_range.onnx
	mkdir -p debian/irlume/opt/irlume/onnxruntime
	cp -a ort-prebuilt/lib debian/irlume/opt/irlume/onnxruntime/
	install -D -m0644 packaging/systemd/irlumed.service \
		debian/irlume/usr/lib/systemd/system/irlumed.service
	install -D -m0644 debian/10-ort.conf \
		debian/irlume/usr/lib/systemd/system/irlumed.service.d/10-ort.conf
	install -D -m0644 packaging/apparmor/usr.bin.irlumed \
		debian/irlume/etc/apparmor.d/usr.bin.irlumed

# Resolve intra-bundle links between the onnxruntime libs without turning
# them into package dependencies.
override_dh_shlibdeps:
	dh_shlibdeps -l$(CURDIR)/debian/irlume/opt/irlume/onnxruntime/lib

# dwz chokes on rust binaries and the prebuilt onnxruntime objects.
override_dh_dwz:
